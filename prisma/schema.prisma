// Prisma schema for AETHER AI
// Mirrors SQLAlchemy models in backend/api/src/models.py
// All PKs are String (UUID v4) matching the Python backend.
// Used for schema management only — runtime queries use SQLAlchemy.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @db.VarChar(36)
  email             String   @unique @db.VarChar(255)
  name              String   @db.VarChar(255)
  password_hash     String   @db.VarChar(255)
  credits_remaining Int      @default(1000)
  role              String   @default("owner") @db.VarChar(40)
  created_at        DateTime @default(now())

  workspaces     Workspace[]
  generations    Generation[]
  audit_logs     AuditLog[]
  refresh_tokens RefreshToken[]

  @@map("users")
}

model Workspace {
  id         String   @id @db.VarChar(36)
  owner_id   String   @db.VarChar(36)
  name       String   @db.VarChar(255)
  plan       String   @default("studio") @db.VarChar(40)
  created_at DateTime @default(now())

  owner          User            @relation(fields: [owner_id], references: [id])
  projects       Project[]
  assets         Asset[]
  datasets       Dataset[]
  training_jobs  TrainingJob[]
  model_registry ModelRegistry[]
  notifications  Notification[]

  @@map("workspaces")
}

model Project {
  id           String   @id @db.VarChar(36)
  workspace_id String   @db.VarChar(36)
  name         String   @db.VarChar(255)
  description  String?
  mode         String   @default("multimodal") @db.VarChar(40)
  created_at   DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id])

  @@map("projects")
}

model Generation {
  id              String   @id @db.VarChar(36)
  user_id         String   @db.VarChar(36)
  mode            String   @db.VarChar(20)
  status          String   @default("queued") @db.VarChar(20)
  prompt          String
  enhanced_prompt String?
  model_used      String?  @db.VarChar(255)
  output_url      String?
  output_text     String?
  credits_used    Int      @default(0)
  created_at      DateTime @default(now())

  user   User    @relation(fields: [user_id], references: [id])
  assets Asset[]

  @@map("generations")
}

model Asset {
  id            String   @id @db.VarChar(36)
  workspace_id  String   @db.VarChar(36)
  generation_id String?  @db.VarChar(36)
  kind          String   @db.VarChar(40)
  name          String   @db.VarChar(255)
  uri           String
  metadata_json Json     @default("{}")
  created_at    DateTime @default(now())

  workspace  Workspace   @relation(fields: [workspace_id], references: [id])
  generation Generation? @relation(fields: [generation_id], references: [id])

  @@map("assets")
}

model Dataset {
  id              String   @id @db.VarChar(36)
  workspace_id    String   @db.VarChar(36)
  source          String   @db.VarChar(40)
  source_ref      String   @db.VarChar(512)
  name            String   @db.VarChar(255)
  status          String   @default("queued") @db.VarChar(40)
  row_count       Int      @default(0)
  media_types     Json     @default("[]")
  columns         Json     @default("[]")
  quality_report  Json     @default("{}")
  lineage         Json     @default("{}")
  preview_samples Json     @default("[]")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  workspace     Workspace     @relation(fields: [workspace_id], references: [id])
  training_jobs TrainingJob[]

  @@map("datasets")
}

model TrainingJob {
  id                  String   @id @db.VarChar(36)
  workspace_id        String   @db.VarChar(36)
  dataset_id          String   @db.VarChar(36)
  status              String   @default("queued") @db.VarChar(40)
  task_type           String   @db.VarChar(60)
  base_model          String   @db.VarChar(255)
  adapter_method      String   @default("lora") @db.VarChar(40)
  progress            Int      @default(0)
  worker_status       String   @default("waiting_for_worker") @db.VarChar(80)
  metrics             Json     @default("{}")
  artifact_paths      Json     @default("{}")
  checkpoint_versions Json     @default("[]")
  error               String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  workspace      Workspace       @relation(fields: [workspace_id], references: [id])
  dataset        Dataset         @relation(fields: [dataset_id], references: [id])
  model_registry ModelRegistry[]

  @@map("training_jobs")
}

model ModelRegistry {
  id                String   @id @db.VarChar(36)
  workspace_id      String   @db.VarChar(36)
  training_job_id   String?  @db.VarChar(36)
  name              String   @db.VarChar(255)
  version           String   @db.VarChar(80)
  base_model        String   @db.VarChar(255)
  artifact_uri      String
  artifact_format   String   @db.VarChar(40)
  metrics           Json     @default("{}")
  deployment_status String   @default("staged") @db.VarChar(40)
  created_at        DateTime @default(now())

  workspace    Workspace    @relation(fields: [workspace_id], references: [id])
  training_job TrainingJob? @relation(fields: [training_job_id], references: [id])

  @@map("model_registry")
}

model AuditLog {
  id            String   @id @db.VarChar(36)
  user_id       String?  @db.VarChar(36)
  action        String   @db.VarChar(120)
  target_type   String   @db.VarChar(80)
  target_id     String?  @db.VarChar(80)
  metadata_json Json     @default("{}")
  created_at    DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

model Notification {
  id           String   @id @db.VarChar(36)
  workspace_id String   @db.VarChar(36)
  kind         String   @db.VarChar(80)
  title        String   @db.VarChar(255)
  body         String
  status       String   @default("unread") @db.VarChar(40)
  created_at   DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id])

  @@map("notifications")
}

model RefreshToken {
  id         String   @id @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  token_hash String   @db.VarChar(255)
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("refresh_tokens")
}
